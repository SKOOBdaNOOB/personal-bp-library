services:
  homebox:
    image: ghcr.io/hay-kot/homebox:latest-rootless
    container_name: {{ service_name }}
    restart: {{ restart_policy }}
    security_opt:
      - no-new-privileges:true
    environment:
      - HBOX_LOG_LEVEL={{ log_level }}
      - HBOX_LOG_FORMAT={{ log_format }}
      - HBOX_WEB_MAX_UPLOAD_SIZE={{ max_upload_size }}
    volumes:
      - ./data:/data/
{% if traefik_enabled %}
    networks:
      - {{ traefik_network }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ service_name }}.rule=Host(`{{ traefik_host }}.{{ traefik_domain }}`)"
      - "traefik.http.routers.{{ service_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ service_name }}.tls.certresolver={{ cert_resolver }}"
      - "traefik.http.services.{{ service_name }}.loadbalancer.server.port=7745"
      - "traefik.docker.network={{ traefik_network }}"
{% else %}
    ports:
      - "{{ port_http }}:7745"
{% endif %}

{% if traefik_enabled %}
networks:
  {{ traefik_network }}:
    external: true
{% endif %}
