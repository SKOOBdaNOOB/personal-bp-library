services:
  portainer:
    image: portainer/portainer-ce:latest
    container_name: {{ service_name }}
    restart: {{ restart_policy }}
    security_opt:
      - no-new-privileges:true
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./data:/data
{% if traefik_enabled %}
    networks:
      - {{ traefik_network }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ service_name }}.rule=Host(`{{ traefik_host }}.{{ traefik_domain }}`)"
      - "traefik.http.routers.{{ service_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ service_name }}.tls.certresolver={{ cert_resolver }}"
      - "traefik.http.services.{{ service_name }}.loadbalancer.server.port=9000"
      - "traefik.docker.network={{ traefik_network }}"
      - "traefik.http.routers.{{ service_name }}-api.rule=Host(`{{ traefik_host }}.{{ traefik_domain }}`) && PathPrefix(`/api/`)"
      - "traefik.http.routers.{{ service_name }}-api.entrypoints=websecure"
      - "traefik.http.routers.{{ service_name }}-api.tls.certresolver={{ cert_resolver }}"
      - "com.centurylinklabs.watchtower.enable=true"
{% else %}
    ports:
      - "{{ port_http }}:9000"
{% endif %}

{% if traefik_enabled %}
networks:
  {{ traefik_network }}:
    external: true
{% endif %}
